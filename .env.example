# Copy this file to .env and fill it on the VPS.

# HTTP listen address inside the container.
ADDR=:8080

# SQLite session database directory inside the container.
DATA_DIR=/data

# Cloudflare Worker inbound webhook endpoint.
# Example: https://wago-worker.your-subdomain.workers.dev/webhooks/whatsapp
WORKER_WEBHOOK_URL=

# Must match SERVICE_TOKEN secret configured in the Cloudflare Worker.
SERVICE_TOKEN=

# Label shown in WhatsApp linked devices. Defaults to "KizeLabs WhatERS".
WHATSAPP_DEVICE_OS_NAME=KizeLabs WhatERS

# Storage backend selection.
# sqlite (current default) or postgres (for upcoming HA migration).
SESSION_STORE_DRIVER=sqlite

# Postgres/Neon settings (used when SESSION_STORE_DRIVER=postgres).
# Runtime should use pooled URL (Neon pooler).
DATABASE_URL=
# Logical schema used by the service.
DATABASE_SCHEMA=public

# HA lease coordination settings (reserved for postgres HA rollout).
LEASE_TTL_SECONDS=30
LEASE_HEARTBEAT_SECONDS=10
LEASE_STALE_GRACE_SECONDS=5

# Two-instance compose, add for more instances.
WA1_HOST_PORT=18081
WA2_HOST_PORT=18082
WA1_INSTANCE_ID=wa-cloud-1
WA2_INSTANCE_ID=wa-cloud-2
WA1_DATA_DIR=./data/wa1
WA2_DATA_DIR=./data/wa2

# Optional container resource limits.
WHATSAPP_CPUS=1.0
WHATSAPP_MEM_LIMIT=512m
WHATSAPP_MEMSWAP_LIMIT=768m
WHATSAPP_PIDS_LIMIT=256
